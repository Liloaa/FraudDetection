@model LoginViewModel
@{
    ViewData["Title"] = "Connexion";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Connexion — FraudDetection</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="auth-wrap">
        <div class="auth-card">
            <h1>Fraud<span style="color:var(--accent)">Detection</span></h1>
            <p class="sub">Connectez-vous pour accéder au dashboard.</p>

            @if (TempData["Succes"] != null)
            {
                <div class="alert-success">@TempData["Succes"]</div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-text">
                    @foreach (var erreur in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@erreur.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                @Html.AntiForgeryToken()
                <div class="field">
                    <label>Email</label>
                    <input asp-for="Email" type="email" required autofocus />
                </div>
                <div class="field">
                    <label>Mot de passe</label>
                    <input asp-for="MotDePasse" type="password" required />
                </div>
                <div class="field" style="display:flex; align-items:center; gap:.4rem">
                    <input asp-for="SeSouvenir" type="checkbox" style="width:auto" />
                    <label style="margin:0">Se souvenir de moi</label>
                </div>
                <button type="submit" class="btn" style="width:100%">Se connecter</button>
            </form>

            <p class="sub" style="margin-top:1.25rem; margin-bottom:0">
                Pas encore de compte ? <a href="/Auth/Inscription">Créer un compte</a>
            </p>
        </div>
    </div>
</body>
</html>