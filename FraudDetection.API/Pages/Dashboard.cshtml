@page "/Dashboard"
@model FraudDetection.API.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p>Vue d'ensemble de l'activité et des alertes en cours.</p>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="label">Transactions</div>
        <div class="value mono">@Model.Resume.TotalTransactions</div>
    </div>
    <div class="stat-card suspect">
        <div class="label">Suspectes</div>
        <div class="value mono">@Model.Resume.TransactionsSuspectes</div>
    </div>
    <div class="stat-card danger">
        <div class="label">Confirmées fraude</div>
        <div class="value mono">@Model.Resume.TransactionsConfirmees</div>
    </div>
    <div class="stat-card">
        <div class="label">Alertes en attente</div>
        <div class="value mono">@Model.Resume.AlertesEnAttente</div>
    </div>
    <div class="stat-card">
        <div class="label">Taux de fraude</div>
        <div class="value mono">@Model.Resume.TauxFraudePourcent %</div>
    </div>
</div>

<div class="panel">
    <h2>Dernières transactions</h2>
    @if (Model.DernieresTransactions.Any())
    {
        <table>
            <thead>
                <tr><th>Date</th><th>Compte</th><th>Montant</th><th>Lieu</th><th>Statut</th></tr>
            </thead>
            <tbody>
                @foreach (var t in Model.DernieresTransactions)
                {
                    <tr>
                        <td class="mono">@t.DateTransaction.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@t.Compte?.NumeroCompte</td>
                        <td class="mono">@t.Montant.ToString("N0") Ar</td>
                        <td>@t.Lieu</td>
                        <td><span class="badge @t.Statut">@t.Statut</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">Aucune transaction pour l'instant.</div>
    }
    <p style="margin-top:.75rem"><a href="/Transactions">Voir toutes les transactions →</a></p>
</div>

<div class="panel">
    <h2>Alertes en attente</h2>
    @if (Model.AlertesRecentes.Any())
    {
        <table>
            <thead>
                <tr><th>Détectée le</th><th>Transaction</th><th>Score</th><th>Raison</th></tr>
            </thead>
            <tbody>
                @foreach (var a in Model.AlertesRecentes)
                {
                    <tr>
                        <td class="mono">@a.DetecteLe.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>#@a.TransactionId</td>
                        <td class="mono">@a.ScoreRisque.ToString("P0")</td>
                        <td>@a.Raison</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">Aucune alerte en attente. 👍</div>
    }
    <p style="margin-top:.75rem"><a href="/Alertes">Voir toutes les alertes →</a></p>

</div>